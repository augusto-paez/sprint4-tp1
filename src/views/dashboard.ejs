<h1>Dashboard Superhéroes</h1>
<br>
<table>
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Nombre Real</th>
            <th>Edad</th>
            <th>Planeta</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        <% superheroes.forEach(superheroe => { %>
        <tr>
            <td><%= superheroe.nombreSuperHeroe %></td>
            <td><%= superheroe.nombreReal %></td>
            <td><%= superheroe.edad %></td>
            <td><%= superheroe.planetaOrigen %></td>
            <td>
                <a href="/heroes/<%= superheroe._id %>/editar" class="btn btn-edit">Editar</a>
                <button class="btn btn-delete" onclick="eliminar('<%= superheroe._id %>')">Eliminar</button>
            </td>
        </tr>
        <% }) %>
    </tbody>
</table>

<script>
    function eliminar(id) {
        if (confirm('¿Estás seguro de que deseas eliminar este superhéroe?')) {
            fetch(`/heroes/${id}`, { method: 'DELETE' })
                .then(() => window.location.reload());
        }
    }
</script>