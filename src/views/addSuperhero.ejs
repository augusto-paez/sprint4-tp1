<h1>Agregar Superhéroe</h1>
<br>
<form action="/heroes/agregar" method="POST">
    <label>Nombre Superhéroe *</label>
    <input type="text" name="nombreSuperHeroe" minlength="3" maxlength="60" required>

    <label>Nombre Real *</label>
    <input type="text" name="nombreReal" minlength="3" maxlength="60" required>

    <label>Edad *</label>
    <input type="number" name="edad" min="0" required>

    <label>Planeta de Origen</label>
    <input type="text" name="planetaOrigen">

    <label>Debilidad</label>
    <input type="text" name="debilidad">

    <label>Poderes * (separados por coma)</label>
    <input type="text" name="poderes" required>

    <label>Aliados (separados por coma)</label>
    <input type="text" name="aliados">

    <label>Enemigos (separados por coma)</label>
    <input type="text" name="enemigos">

    <label>Creador</label>
    <input type="text" name="creador">

    <div class="form-actions">
        <button type="submit" class="btn btn-save">Guardar</button>
        <a href="/" class="btn btn-cancel">Cancelar</a>
    </div>
</form>